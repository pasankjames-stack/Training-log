<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
<title>Training Dashboard</title>
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Dashboard" />
<meta name="theme-color" content="#EEEFF1" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

<style>
  :root {
    --ink: #15191F;
    --ink-soft: #5A636E;
    --ink-faint: #99A1AB;
    --paper: #EEEFF1;
    --card: #FFFFFF;
    --line: #E2E4E8;
    --accent: #F0521E;
    --accent-ink: #C23C0E;
    --up: #1E9E6B;
    --shadow: 0 1px 2px rgba(20,24,31,.05), 0 8px 24px rgba(20,24,31,.06);
    --display: "Space Grotesk", system-ui, sans-serif;
    --body: "Inter", system-ui, sans-serif;
    --mono: "Space Mono", ui-monospace, monospace;
  }
  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body { margin: 0; }
  body { font-family: var(--body); background: var(--paper); color: var(--ink); line-height: 1.45; -webkit-font-smoothing: antialiased; }
  .app { max-width: 480px; margin: 0 auto; padding: 18px 16px 40px; }

  header { padding: 6px 2px 14px; display: flex; justify-content: space-between; align-items: flex-end; }
  .kicker { font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-faint); font-weight: 700; }
  h1 { font-family: var(--display); font-weight: 700; font-size: 27px; margin: 2px 0 0; letter-spacing: -.01em; }
  .refresh { border: 1.5px solid var(--line); background: var(--card); border-radius: 10px; padding: 8px 12px; font-family: var(--display); font-weight: 600; font-size: 12px; color: var(--ink); cursor: pointer; }

  .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .stat { background: var(--card); border-radius: 14px; padding: 13px 14px; box-shadow: var(--shadow); }
  .stat .lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-faint); }
  .stat .val { font-family: var(--display); font-weight: 700; font-size: 23px; margin-top: 3px; letter-spacing: -.01em; }
  .stat .val small { font-size: 13px; color: var(--ink-soft); font-weight: 600; }

  .card { background: var(--card); border-radius: 16px; padding: 15px 15px 13px; margin-bottom: 11px; box-shadow: var(--shadow); }
  .card h2 { font-family: var(--display); font-weight: 700; font-size: 15px; margin: 0 0 2px; }
  .card .csub { font-size: 11.5px; color: var(--ink-soft); margin-bottom: 12px; }

  .chart { width: 100%; height: auto; display: block; }
  .axis { font-family: var(--mono); font-size: 9px; fill: var(--ink-faint); }

  .pcard { padding: 12px 2px 0; border-top: 1px solid var(--line); }
  .pcard:first-child { border-top: none; padding-top: 2px; }
  .pname { font-family: var(--display); font-weight: 700; font-size: 13.5px; margin-bottom: 9px; display: flex; justify-content: space-between; align-items: baseline; }
  .pname .pday { color: var(--ink-faint); font-weight: 400; font-size: 11px; }
  .ptrack { display: flex; align-items: flex-end; gap: 5px; height: 50px; }
  .pbar { flex: 1; background: #ECEEF1; border-radius: 5px 5px 0 0; position: relative; min-height: 4px; }
  .pbar.last { background: var(--accent); }
  .pbar .pv { position: absolute; top: -15px; left: 0; right: 0; text-align: center; font-family: var(--mono); font-size: 9.5px; color: var(--ink-soft); }
  .pdates { display: flex; gap: 5px; margin-top: 4px; }
  .pdates span { flex: 1; text-align: center; font-family: var(--mono); font-size: 9px; color: var(--ink-faint); }

  .state { text-align: center; padding: 50px 20px; color: var(--ink-soft); }
  .state .big { font-family: var(--display); font-weight: 700; font-size: 17px; color: var(--ink); margin-bottom: 6px; }
  .state.err .big { color: var(--accent-ink); }
  .foot { text-align: center; margin-top: 18px; }
  .foot a { font-family: var(--display); font-weight: 600; font-size: 13px; color: var(--accent-ink); text-decoration: none; }
  .loading { text-align: center; padding: 60px 20px; color: var(--ink-faint); font-family: var(--mono); font-size: 13px; }
</style>

<div class="app">
  <header>
    <div>
      <div class="kicker">From your Google Sheet</div>
      <h1>Dashboard</h1>
    </div>
    <button class="refresh" id="refreshBtn">↻ Refresh</button>
  </header>
  <div id="view"><div class="loading">Loading from your sheet…</div></div>
  <div class="foot"><a href="./index.html">← Back to the log</a></div>
</div>

<script>
// Reads the SAME web-app URL your log writes to. JSONP sidesteps browser CORS.
const WEBAPP_URL = "https://script.google.com/macros/s/AKfycbwJS-ycOjHqyywYP9Zgdr4cfv6tnyzRCbzyypYd6SrKh_axauRN2zOD7KK4XvGzFyRs/exec";
const LS_KEY = "ulp-tracker-v1";

const view = document.getElementById("view");

// ---------- Load: try the Sheet, fall back to local data ----------
function jsonp(url, cb) {
  const fn = "__cb" + Math.random().toString(36).slice(2);
  let done = false;
  const cleanup = () => { delete window[fn]; s.remove(); clearTimeout(timer); };
  window[fn] = (data) => { if (done) return; done = true; cleanup(); cb(null, data); };
  const s = document.createElement("script");
  s.src = url + (url.includes("?") ? "&" : "?") + "callback=" + fn + "&t=" + Date.now();
  s.onerror = () => { if (done) return; done = true; cleanup(); cb(new Error("network")); };
  const timer = setTimeout(() => { if (done) return; done = true; cleanup(); cb(new Error("timeout")); }, 12000);
  document.body.appendChild(s);
}

// Sheet rows -> normalized records
function fromSheet(payload) {
  const rows = (payload && payload.rows) || [];
  const out = [];
  rows.forEach((r, i) => {
    if (i === 0 && String(r[0]).toLowerCase() === "date") return; // header
    if (!r || r.length < 6) return;
    out.push(normalize(r[0], r[1], r[2], r[4], r[5]));
  });
  return out;
}
// localStorage sessions -> normalized records (same shape)
function fromLocal() {
  let data; try { data = JSON.parse(localStorage.getItem(LS_KEY)); } catch (e) { return []; }
  if (!data || !data.sessions) return [];
  const out = [];
  data.sessions.forEach(s => {
    Object.keys(s.ex || {}).forEach(id => {
      (s.ex[id] || []).forEach(x => {
        // exercise display name isn't stored locally; use the id as a fallback label
        out.push(normalize(s.date, s.day, id, x.w, x.r));
      });
    });
  });
  return out;
}
function normalize(date, day, exercise, weight, reps) {
  let d = String(date);
  if (d.includes("T")) d = d.slice(0, 10);       // ISO datetime -> date
  const w = (weight === "BW" || weight === "" || weight == null) ? null : Number(weight);
  return { date: d, day: String(day), exercise: String(exercise),
           weight: (w == null || isNaN(w)) ? null : w, reps: Number(reps) || 0 };
}

// ---------- Aggregate ----------
function toSessions(recs) {
  const map = {};
  recs.forEach(r => {
    const key = r.date + "|" + r.day;
    if (!map[key]) map[key] = { date: r.date, day: r.day, volume: 0 };
    if (r.weight != null && r.reps > 0) map[key].volume += r.weight * r.reps;
  });
  return Object.values(map).sort((a, b) => a.date.localeCompare(b.date));
}
function byExercise(recs) {
  const map = {};
  recs.forEach(r => {
    if (r.weight == null) return;
    const k = r.exercise + "|" + r.day;
    if (!map[k]) map[k] = { name: r.exercise, day: r.day, points: {} };
    const cur = map[k].points[r.date] || 0;
    if (r.weight > cur) map[k].points[r.date] = r.weight;
  });
  return Object.values(map).map(e => ({
    name: e.name, day: e.day,
    series: Object.keys(e.points).sort().map(d => ({ date: d, w: e.points[d] }))
  })).filter(e => e.series.length);
}
function daysAgo(dateStr) {
  const d = new Date(dateStr + "T00:00:00"), now = new Date();
  return Math.round((now.setHours(0,0,0,0) - d.setHours(0,0,0,0)) / 86400000);
}
function prettyShort(dateStr) {
  return new Date(dateStr + "T00:00:00").toLocaleDateString(undefined, { day: "numeric", month: "short" });
}

// ---------- Render ----------
function render(recs) {
  if (!recs.length) {
    view.innerHTML = `<div class="state"><div class="big">No sessions yet</div>Log a workout in the app and it'll appear here.</div>`;
    return;
  }
  const sessions = toSessions(recs);
  const totalVol = sessions.reduce((s, x) => s + x.volume, 0);
  const last = sessions[sessions.length - 1];
  const ago = daysAgo(last.date);
  const lastTxt = ago <= 0 ? "Today" : ago === 1 ? "Yesterday" : ago + " days ago";
  const week = sessions.filter(s => daysAgo(s.date) <= 6).length;

  let html = `<div class="stats">
    <div class="stat"><div class="lbl">Sessions</div><div class="val">${sessions.length}</div></div>
    <div class="stat"><div class="lbl">Last 7 days</div><div class="val">${week} <small>session${week===1?"":"s"}</small></div></div>
    <div class="stat"><div class="lbl">Total volume</div><div class="val">${Math.round(totalVol).toLocaleString()} <small>kg</small></div></div>
    <div class="stat"><div class="lbl">Last trained</div><div class="val" style="font-size:18px">${lastTxt}</div></div>
  </div>`;

  html += `<div class="card"><h2>Volume per session</h2>
    <div class="csub">Total weight moved (weight × reps) each session</div>
    ${volumeChart(sessions.slice(-14))}</div>`;

  const exs = byExercise(recs);
  if (exs.length) {
    html += `<div class="card"><h2>Working weight by exercise</h2>
      <div class="csub">Top set over your recent sessions</div>`;
    exs.forEach(e => {
      const pts = e.series.slice(-6);
      const max = Math.max(...pts.map(p => p.w), 1);
      let bars = "", dates = "";
      pts.forEach((p, i, arr) => {
        const isLast = i === arr.length - 1;
        const h = Math.max(8, (p.w / max) * 100);
        bars += `<div class="pbar ${isLast ? "last" : ""}" style="height:${h}%"><span class="pv">${p.w}</span></div>`;
        dates += `<span>${prettyShort(p.date)}</span>`;
      });
      html += `<div class="pcard"><div class="pname"><span>${e.name}</span><span class="pday">${e.day}</span></div>
        <div class="ptrack">${bars}</div><div class="pdates">${dates}</div></div>`;
    });
    html += `</div>`;
  }
  view.innerHTML = html;
}

function volumeChart(sessions) {
  if (sessions.length < 2) {
    const v = sessions.length ? Math.round(sessions[0].volume).toLocaleString() : 0;
    return `<div style="font-family:var(--mono);font-size:12px;color:var(--ink-soft);padding:6px 0">
      ${v} kg so far — log another session to start the trend.</div>`;
  }
  const W = 320, H = 120, padL = 6, padR = 6, padT = 16, padB = 18;
  const vals = sessions.map(s => s.volume);
  const max = Math.max(...vals), min = Math.min(...vals, 0);
  const span = (max - min) || 1;
  const x = i => padL + (i * (W - padL - padR)) / (sessions.length - 1);
  const y = v => padT + (1 - (v - min) / span) * (H - padT - padB);
  let line = "", area = `M ${x(0)} ${H - padB}`;
  sessions.forEach((s, i) => {
    const px = x(i), py = y(s.volume);
    line += (i ? " L " : "M ") + px.toFixed(1) + " " + py.toFixed(1);
    area += ` L ${px.toFixed(1)} ${py.toFixed(1)}`;
  });
  area += ` L ${x(sessions.length - 1)} ${H - padB} Z`;
  let dots = "", labels = "";
  sessions.forEach((s, i) => {
    const show = sessions.length <= 8 || i === 0 || i === sessions.length - 1 || i === Math.floor(sessions.length / 2);
    dots += `<circle cx="${x(i).toFixed(1)}" cy="${y(s.volume).toFixed(1)}" r="${i === sessions.length-1 ? 3.5 : 2.2}" fill="${i === sessions.length-1 ? 'var(--accent)' : 'var(--ink-faint)'}"/>`;
    if (show) labels += `<text class="axis" x="${x(i).toFixed(1)}" y="${H - 5}" text-anchor="middle">${prettyShort(s.date)}</text>`;
  });
  return `<svg class="chart" viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">
    <path d="${area}" fill="var(--accent)" opacity="0.08"/>
    <path d="${line}" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
    ${dots}${labels}
  </svg>`;
}

// ---------- Boot ----------
function loadAndRender() {
  view.innerHTML = `<div class="loading">Loading from your sheet…</div>`;
  if (!WEBAPP_URL) { render(fromLocal()); return; }
  jsonp(WEBAPP_URL, (err, payload) => {
    if (err) {
      const local = fromLocal();
      if (local.length) { render(local); return; }
      view.innerHTML = `<div class="state err"><div class="big">Couldn't reach the sheet</div>
        Check that your Apps Script has a <b>doGet</b> and was redeployed as a new version with access set to “Anyone”. ${err.message === "timeout" ? "(It timed out.)" : ""}</div>`;
      return;
    }
    let recs = fromSheet(payload);
    if (!recs.length) recs = fromLocal();
    render(recs);
  });
}
document.getElementById("refreshBtn").onclick = loadAndRender;
loadAndRender();
</script>
